<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/nav') %>

  <main>
    <section class="page-hero">
      <div class="container narrow">
        <p class="eyebrow"><%= industry.eyebrow %></p>
        <h1><%= industry.hero %></h1>
        <p class="lead"><%= industry.lead %></p>
        <div class="cta-row">
          <a class="button primary" href="/contact">Request a Sample List</a>
          <a class="button secondary" href="/services">View All Services</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">What's included</p>
          <h2>Why our <%= industry.eyebrow %> data delivers results.</h2>
        </div>
        <div class="card-grid three">
          <% industry.highlights.forEach(function(h) { %>
          <article class="card">
            <h3><%= h.title %></h3>
            <p><%= h.body %></p>
          </article>
          <% }); %>
        </div>
      </div>
    </section>

    <section class="section accent-band">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Data fields included</p>
          <h2>Every record is built for campaign-ready use.</h2>
        </div>
        <div class="pill-grid">
          <% industry.fields.forEach(function(f) { %>
          <span><%= f %></span>
          <% }); %>
        </div>
      </div>
    </section>

    <section class="section dark-panel">
      <div class="container split-grid">
        <div>
          <p class="eyebrow light">Data at a glance</p>
          <h2>Numbers that reflect the depth and quality of our <%= industry.eyebrow %> lists.</h2>
        </div>
        <div class="metrics-grid">
          <% industry.stats.forEach(function(s) { %>
          <div>
            <strong><%= s.value %></strong>
            <p><%= s.label %></p>
          </div>
          <% }); %>
        </div>
      </div>
    </section>

    <section class="section cta-section">
      <div class="container cta-box">
        <div>
          <p class="eyebrow">Ready to reach the right audience?</p>
          <h2>Get your custom <%= industry.label %> tailored to your campaign goals.</h2>
        </div>
        <a class="button primary" href="/contact">Request Your List</a>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/site.js"></script>
</body>
</html>
